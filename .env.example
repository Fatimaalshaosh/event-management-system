# Local development environment for the Presidential Protocol platform.
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
#
# These are read by the api-server (and tooling). The frontend itself only needs
# PORT/BASE_PATH (which now default to 5173 / "/" locally).

# --- Database (required for the api-server) ---
# PostgreSQL connection string. Examples:
#   Local:  postgres://postgres:postgres@localhost:5432/presidential
#   Neon:   postgres://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

# --- API server ---
PORT=8080
BASE_PATH=/

# --- AI features (OpenAI) ---
# Used by @workspace/integrations-openai-ai-server for the AI Copilot / reports
# AND for executive portrait generation (POST /api/portraits/generate).
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Executive portrait generation ---
# Backend image provider for /api/portraits/generate. Default: openai.
# Future drop-ins: gemini | flux | azure | localpack.
PORTRAIT_PROVIDER=openai
# Where generated portraits are stored (stable + cached). Default: api-server/.portraits
# PORTRAITS_DIR=
# Frontend opt-in flag. Set to "openai" to route avatars through the backend
# provider. Leave BLANK to keep current photo/placeholder avatars (off by default).
VITE_PORTRAITS=

# --- Object storage (optional — document uploads) ---
# Google Cloud Storage. Leave blank to disable uploads.
# GOOGLE_APPLICATION_CREDENTIALS=
# GCS_BUCKET=

# --- Frontend dev (optional overrides) ---
# Where the Vite dev server proxies /api during local development.
# API_PROXY_TARGET=http://localhost:8080
